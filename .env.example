# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=YourEscrowBot

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/telegram-escrow
REDIS_URL=redis://localhost:6379

# Admin Settings
DEFAULT_FEE_PERCENT=3
AUTO_CANCEL_TIMEOUT_MINUTES=120
REMINDER_INTERVAL_MINUTES=30
LOG_CHANNEL_ID=-1001234567890

# Server Configuration (optional for webhooks)
PORT=3000
WEBHOOK_URL=https://yourdomain.com/webhook

# Admin Usernames (comma-separated Telegram usernames without @)
SUPER_ADMINS=admin,user1,user2
MODERATORS=mod1,mod2
ESCROWERS=escrower1,escrower2
